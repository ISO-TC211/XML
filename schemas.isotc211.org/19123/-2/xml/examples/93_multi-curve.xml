<?xml version="1.0" encoding="UTF-8"?>

<MultiCurveCoverage
  xmlns="https://schemas.isotc211.org/schemas/19123/-2/cis/1.2"
  xmlns:swe="http://www.opengis.net/swe/2.0"
  xmlns:gml="http://www.opengis.net/gml/3.2"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="https://schemas.isotc211.org/schemas/19123/-2/cis/1.2 cisAll.xsd 
                      http://www.opengis.net/swe/2.0 sweAll.xsd 
                      http://www.opengis.net/gml/3.2 https://schemas.isotc211.org/schemas/19136/-/gml/1.0/gml.xsd"
  gml:id="CIS_93">
  
  <Envelope srsName="[EPSG:4326]" axisLabels="Lat Lon">
    <AxisExtent axisLabel="Lat" uomLabel="deg" lowerBound="1.1" upperBound="5.5"/>
    <AxisExtent axisLabel="Lon" uomLabel="deg" lowerBound="1.1" upperBound="5.5"/>
  </Envelope>
  
  <DomainSet>
    <gml:MultiCurve gml:id="mc1">
      <gml:curveMember>
        <gml:LineString gml:id="ls1">
          <gml:posList>1.1 1.1 2.2 2.2</gml:posList>
        </gml:LineString>
      </gml:curveMember>
      <gml:curveMember>
        <gml:LineString gml:id="ls2">
          <gml:posList>2.2 2.2 3.3 3.3</gml:posList>
        </gml:LineString>
      </gml:curveMember>
      <gml:curveMember>
        <gml:LineString gml:id="ls3">
          <gml:posList>3.3 3.3 4.4 4.4</gml:posList>
        </gml:LineString>
      </gml:curveMember>
      <gml:curveMember>
        <gml:LineString gml:id="ls4">
          <gml:posList>4.4 4.4 5.5 5.5</gml:posList>
        </gml:LineString>
      </gml:curveMember>
    </gml:MultiCurve>
  </DomainSet>
  
  <RangeSet>
    <DataBlock>
      <CV><V>10</V><V>1013</V></CV>
      <CV><V>20</V><V>1012</V></CV>
      <CV><V>30</V><V>1011</V></CV>
      <CV><V>40</V><V>1010</V></CV>
    </DataBlock>
  </RangeSet>
  
  <RangeType>
    <swe:DataRecord>
      <swe:field name="temperature">
        <swe:Quantity definition="http://www.opengis.net/def/property/OGC/0/Temperature">
          <swe:uom code="Cel"/>
        </swe:Quantity>
      </swe:field>
      <swe:field name="pressure">
        <swe:Quantity definition="http://www.opengis.net/def/property/OGC/0/Pressure">
          <swe:uom code="hPa"/>
        </swe:Quantity>
      </swe:field>
    </swe:DataRecord>
  </RangeType>
  
</MultiCurveCoverage>